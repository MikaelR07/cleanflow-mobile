# CleanFlow Environment Variables Placeholder
# Copy this to .env.local and fill in the values from your Supabase Dashboard

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: App Features
# VITE_HYGENEX_AI_ENABLED=true

# ──────────────────────────────────────────────────────────────────────────────
# PRODUCTION DEPLOYMENT URLS (Netlify)
# Update these with your actual Netlify domains after deployment
# ──────────────────────────────────────────────────────────────────────────────
VITE_URL_CLIENT=https://YOUR_CLIENT_APP.netlify.app
VITE_URL_AGENT=https://YOUR_AGENT_APP.netlify.app
VITE_URL_BUSINESS=https://YOUR_BUSINESS_HUB.netlify.app
VITE_URL_MARKETING=https://YOUR_MARKETING_PORTAL.netlify.app

# ──────────────────────────────────────────────────────────────────────────────
# SECURITY CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
# Secret key required to register as an Admin
VITE_ADMIN_REGISTRATION_KEY=change_this_to_a_secure_key
